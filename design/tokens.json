      "$value": {
        "fontFamily": "JetBrains Mono, monospace",
        "fontSize": {
          "value": 0.8125,
          "unit": "rem"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0.02,
          "unit": "em"
        }
      }
    }
  }
