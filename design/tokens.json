    "4": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "6": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "8": {
      "$value": {
        "value": 64,
        "unit": "px"
      }
    },
    "12": {
      "$value": {
        "value": 96,
        "unit": "px"
      }
    },
    "16": {
      "$value": {
        "value": 128,
        "unit": "px"
      }
    },
    "$type": "dimension",
    "grid": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "base": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display-xl": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Archivo Expanded, Archivo, sans-serif",
        "fontSize": {
          "value": 3,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": 0.08,
          "unit": "em"
        }
      }
    },
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Archivo Expanded, Archivo, sans-serif",
        "fontSize": {
          "value": 2,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": 0.08,
          "unit": "em"
        }
      }
    },
    "titulo": {
      "$type": "typography",
      "$value": {
        "fontFamily": "IBM Plex Sans, sans-serif",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": 0,
          "unit": "em"
        }
